# Kalshi API Credentials
# Generate at: https://kalshi.com/account/profile -> API Keys
KALSHI_API_KEY_ID=your-api-key-id-here
KALSHI_PRIVATE_KEY_PATH=~/.key/kalshi/key.pem

# Environment: "demo" or "prod"
KALSHI_ENV=demo

# Trading Configuration
MARKET_SERIES=KXBTC15M
STAKE_USD=5.00
MAX_DAILY_LOSS_USD=25.00
MAX_CONCURRENT_POSITIONS=3

# Strategy Selection: momentum, mean_reversion, consensus, all
STRATEGY=all

# Paper Trading (set to false for real money)
PAPER_TRADE=true
PAPER_BALANCE=100.00

# Daily market stake
DAILY_STAKE_USD=15.00

# Resolution rider stake
RESOLUTION_RIDER_STAKE_USD=15.00

# SSE Server (dashboard data feed)
SSE_PORT=5050

# Data directory for tick recordings and historical data
# Local (WSL): /mnt/d/datasets/prediction-market-analysis
# VPS: /home/kalshi/data
DATA_DIR=/mnt/d/datasets/prediction-market-analysis

# Dashboard password (leave empty to disable auth)
DASHBOARD_PASSWORD=your-password-here

# Santiment API (optional)
# Free tier: https://app.santiment.net/account#api-keys
SANTIMENT_API_KEY=
