# ─── Kalshi API Credentials ──────────────────────────────────────────
# Generate at: https://kalshi.com/account/profile -> API Keys
KALSHI_API_KEY_ID=your-api-key-id-here
KALSHI_PRIVATE_KEY_PATH=~/.key/kalshi/key.pem

# Environment: "demo" or "prod"
KALSHI_ENV=prod

# ─── Rate Limits ─────────────────────────────────────────────────────
# Per-key token-bucket caps. Kalshi's documented limits are 20 reads/s
# and 10 writes/s; defaults below run at 75% to leave burst headroom.
# Lower these if you see recurring 429s in the [KALSHI-API] summary
# line; raise them only if "waits" is high and "429" stays zero.
# KALSHI_READ_RATE=15
# KALSHI_WRITE_RATE=8

# ─── Trading Mode ────────────────────────────────────────────────────
# PAPER_TRADE=true simulates orders locally. Set to false for real money.
# PAPER_BALANCE seeds the simulated account in paper mode.
PAPER_TRADE=true
PAPER_BALANCE=100.00

# ─── Strategy ────────────────────────────────────────────────────────
# Resolution Rider is the only live strategy. Per-cell parameters
# (min/max seconds, buffer, momentum gate, etc.) are loaded from
# data/rr_params.json — re-run optimize_rr.py every 3-4 days to refresh.
STRATEGY=resolution_rider

# Flat stake per RR trade. No Kelly — variance is low enough that
# one knob is easier to reason about than separate 15M / daily / Kelly
# sizing. Applies to every cell and every market type.
STAKE_USD=10.00

# ─── Risk Guardrails ─────────────────────────────────────────────────
# Hard daily loss cap — bot pauses new entries when daily P&L dips
# below -MAX_DAILY_LOSS_USD. Data collection continues while paused.
MAX_DAILY_LOSS_USD=25.00

# Enable all RR cells regardless of optimizer safety gate.
# Only set to 1 after validating with a backtest. Default: 0 (only
# cells with WR_LB >= 93% or positive CV profit are enabled).
# RR_ENABLE_ALL=0

# Max concurrent open positions across all assets.
MAX_CONCURRENT_POSITIONS=3

# Legacy display-only — RR scans every crypto series regardless of this.
MARKET_SERIES=KXBTC15M

# ─── Data & Dashboard ────────────────────────────────────────────────
# Root for ALL collected data the bot writes:
#   $DATA_DIR/ticks/YYYY-MM-DD.csv        (WS bid/ask/last, deduped)
#   $DATA_DIR/prices/YYYY-MM-DD.csv       (1-min spot)
#   $DATA_DIR/prices_hf/YYYY-MM-DD.csv    (5-sec spot)
#   $DATA_DIR/orderbooks/YYYY-MM-DD.csv   (depth snapshots)
# Also the root under which historical parquet datasets (HF, misterrPink1)
# live when you have them. If unset, every writer falls back to the
# repo-relative python-bot/data/ directory — nothing breaks on a fresh
# clone. To migrate an existing install: stop the bot, move the four
# subdirs above into $DATA_DIR, restart; optimize_rr and analyze_*
# will find files in either location during the overlap.
# Local (WSL): /mnt/d/datasets/prediction-market-analysis
# VPS:         /home/kalshi/data
DATA_DIR=/mnt/d/datasets/prediction-market-analysis

# SSE server port for the dashboard data feed.
SSE_PORT=5050

# Dashboard auth — leave empty to disable the password prompt.
DASHBOARD_PASSWORD=

# ─── Optional: Santiment sentiment feed ──────────────────────────────
# Free tier: https://app.santiment.net/account#api-keys
# Only used for dashboard display; trading does not depend on it.
SANTIMENT_API_KEY=
