# Kalshi API Credentials
# Generate at: https://kalshi.com/account/profile -> API Keys
KALSHI_API_KEY_ID=your-api-key-id-here
KALSHI_PRIVATE_KEY_PATH=~/.key/kalshi/key.pem

# Environment: "demo" or "prod"
KALSHI_ENV=demo

# Trading Configuration
MARKET_SERIES=KXBTC15M          # KXBTC15M for Bitcoin, KXETH15M for Ethereum
STAKE_USD=5.00                   # USD per trade
MAX_DAILY_LOSS_USD=25.00         # Stop trading after this daily loss
MAX_CONCURRENT_POSITIONS=3       # Max open positions at once
POLL_INTERVAL_SECONDS=5          # How often to check markets

# Strategy Selection: momentum, mean_reversion, consensus, all
STRATEGY=consensus

# Paper Trading (set to false for real money)
PAPER_TRADE=true
